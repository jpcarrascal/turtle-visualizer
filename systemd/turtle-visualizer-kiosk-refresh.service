[Unit]
Description=One-shot kiosk refresh after boot
After=turtle-visualizer-kiosk.service
Wants=turtle-visualizer-kiosk.service

[Service]
Type=oneshot
Environment=KIOSK_REFRESH_DELAY=20
ExecStart=/bin/sh -c 'sleep "$KIOSK_REFRESH_DELAY"; systemctl restart turtle-visualizer-kiosk.service; sleep 6; systemctl restart turtle-visualizer-kiosk.service'

[Install]
WantedBy=multi-user.target
